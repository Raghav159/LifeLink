FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --legacy-peer-deps

# Copy source
COPY frontend/ .

# Build app
RUN npm run build

# Expose Vite preview port
EXPOSE 3000

# Run preview server
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "3000"]